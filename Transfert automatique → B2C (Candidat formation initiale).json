        "jsCode": "// Récupération du champ avec fallback\nconst raw = $json['Numéro de téléphone'];\n\n\n// Si pas de numéro → retourner un champ vide\nif (!raw) {\n  return {\n    json: {\n      numero_formatte: \"\"\n    }\n  };\n}\n\n// Nettoyage : retirer tout sauf les chiffres\nlet digits = raw.toString().replace(/\\D+/g, \"\");\n\n// Cas 1 : commence par 33 (ex : 33745744591)\nif (digits.startsWith(\"33\")) {\n  digits = digits.substring(2); \n}\n\n// Cas 2 : commence par 330...\nif (digits.startsWith(\"330\")) {\n  digits = digits.substring(3);\n}\n\n// Cas 3 : commence par 0\nif (digits.startsWith(\"0\")) {\n  digits = digits.substring(1);\n}\n\n// Cas 4 : si trop court ou vide → invalide\nif (digits.length < 9) {\n  return {\n    json: {\n      numero_formatte: \"\"\n    }\n  };\n}\n\n// Ajout du +33 final\nconst final = \"+33\" + digits;\n\nreturn {\n  json: {\n    numero_formatte: final\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
