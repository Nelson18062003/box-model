      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Récupération sécurisée de la civilité depuis l'item\nconst civRaw = $('If').item.json['Civilité'] ;\n\n// Valeur finale\nlet civ;\n\n// Cas : monsieur\nif (civRaw === \"monsieur\" || civRaw === \"Monsieur\" || civRaw === \"mr\" || civRaw === \"m\") {\n  civ = \"M.\";\n}\n\n// Cas : madame\nelse if (civRaw === \"madame\" || civRaw === \"Madame\" || civRaw === \"mme\" || civRaw === \"m me\") {\n  civ = \"Mme\";\n}\n\n// Cas : vide ou valeur inconnue → par défaut Mme.\nelse {\n  civ = \"Mme\";\n}\n\nreturn {\n  json: {\n    civilite_formatee: civ\n  }\n};\n"
      },
