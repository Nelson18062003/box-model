    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Petite fonction utilitaire pour formater une Date en \"JJ/MM/AAAA\"\nfunction formatDate(d) {\n  const day = String(d.getDate()).padStart(2, '0');\n  const month = String(d.getMonth() + 1).padStart(2, '0');\n  const year = d.getFullYear();\n  return `${day}/${month}/${year}`;\n}\n\n// 1️⃣ Traitement de \"Date de creation\" (timestamp HubSpot)\nlet dateCreationFormatee = '';\nconst rawCreation =$json['Date de creation'];\n\nif (rawCreation) {\n  let ts = Number(rawCreation);\n\n  // Si HubSpot renvoie des secondes (10 chiffres), on convertit en ms\n  if (ts < 1e11) {\n    ts = ts * 1000;\n  }\n\n  const d = new Date(ts);\n  if (!isNaN(d.getTime())) {\n    dateCreationFormatee = formatDate(d); // ex : \"04/12/2025\"\n  }\n}\n\n// 2️⃣ Traitement de \"Date de transfert vers B2C\" (ISO string)\nlet dateTransfertFormatee = '';\nconst rawTransfert = $json['Date de transfer vers B2C'];\n\nif (rawTransfert) {\n  const d2 = new Date(rawTransfert);\n  if (!isNaN(d2.getTime())) {\n    dateTransfertFormatee = formatDate(d2); // ex : \"04/12/2025\"\n  }\n}\n\n// On renvoie toutes les données d'origine + les deux nouveaux champs formatés\nreturn {\n  json: {\n    ...$json,\n    date_creation_formatee: dateCreationFormatee,\n    date_transfert_formatee: dateTransfertFormatee,\n  }\n};\n"
      },
